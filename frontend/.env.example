# ThreadSeeker frontend — environment variables
#
# The frontend is fully client-side. Most search calls go straight to public
# APIs (GitHub, HF, GitLab, npm, PyPI, crates.io, HN, Codeberg, Packagist,
# RubyGems) — the backend is only needed for Reddit + AI features.
#
# If you leave NEXT_PUBLIC_BACKEND_URL blank, the app still works but Reddit
# search, AI query optimization, and cross-source synthesis are disabled.

# URL of the ThreadSeeker Python backend (e.g. https://api.threadseeker.example.com)
NEXT_PUBLIC_BACKEND_URL=
