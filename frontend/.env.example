# ThreadSeeker frontend — environment variables
#
# The backend now ships as Cloudflare Pages Functions alongside the frontend,
# so in production `/api/*` is same-origin and no env vars are required.
#
# For local dev without `wrangler pages dev`, set this to "disabled" to
# suppress the Reddit / AI calls (everything else still works against the
# 10 public APIs). To point at a local Wrangler instance, set it to
# something like http://localhost:8788.
#
# NEXT_PUBLIC_BACKEND_URL=disabled
NEXT_PUBLIC_BACKEND_URL=
