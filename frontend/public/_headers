/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self'; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'

# Hashed Next static assets are immutable — cache hard.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Vendored semantic-rerank model weights (~24 MB, pinned to a specific HF
# revision SHA in scripts/fetch-semantic-assets.mjs, so content at this path
# genuinely never changes — model upgrades MUST use a new directory) — cache
# hard so the browser HTTP cache covers visitors even before transformers.js'
# own Cache API does.
/models/*
  Cache-Control: public, max-age=31536000, immutable

# Generated metadata image. Served extensionless, so set the type explicitly —
# with the global nosniff, social scrapers can't recover it via MIME-sniffing.
/opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400

# Generated app icons (icon0/1/2.tsx / apple-icon.tsx) — same extensionless
# ImageResponse routes, same nosniff constraint.
/icon0
  Content-Type: image/png
  Cache-Control: public, max-age=86400
/icon1
  Content-Type: image/png
  Cache-Control: public, max-age=86400
/icon2
  Content-Type: image/png
  Cache-Control: public, max-age=86400
/apple-icon
  Content-Type: image/png
  Cache-Control: public, max-age=86400

# PWA manifest (generated by app/manifest.ts). Pinned so nosniff can't leave
# installability hanging on the host's .webmanifest MIME mapping.
/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=86400

# CSP notes:
# - script-src 'self' 'unsafe-inline': the static export can't mint a per-request
#   nonce, and Next ships per-build inline bootstrap + the ld+json + next-themes
#   anti-FOUC scripts. 'self' still blocks injected EXTERNAL <script src>, and
#   with safeHref() neutralizing javascript: hrefs there is no inline-XSS sink.
# - 'wasm-unsafe-eval' + cdn.jsdelivr.net: the keyless semantic reranker
#   (public/workers/semantic-embed.worker.js) runtime-imports a PINNED
#   transformers.js build from jsDelivr and compiles the ONNX WASM runtime.
#   'wasm-unsafe-eval' permits WebAssembly compilation only — NOT JS eval().
#   Model weights arrive via fetch (connect-src https:), not script-src.
# - connect-src / img-src stay broad (https:) on purpose: the app fetches ~40
#   upstream hosts (directly + via the same-origin proxy) and renders avatars/
#   icons from arbitrary hosts. Tightening these to a build-generated allowlist
#   from a shared host constant is the next step; broad-https is the safe start.
