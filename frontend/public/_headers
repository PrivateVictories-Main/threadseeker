/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self'; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'

# Hashed Next static assets are immutable — cache hard.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Generated metadata image. Served extensionless, so set the type explicitly —
# with the global nosniff, social scrapers can't recover it via MIME-sniffing.
/opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400

# CSP notes:
# - script-src 'self' 'unsafe-inline': the static export can't mint a per-request
#   nonce, and Next ships per-build inline bootstrap + the ld+json + next-themes
#   anti-FOUC scripts. 'self' still blocks injected EXTERNAL <script src>, and
#   with safeHref() neutralizing javascript: hrefs there is no inline-XSS sink.
# - connect-src / img-src stay broad (https:) on purpose: the app fetches ~40
#   upstream hosts (directly + via the same-origin proxy) and renders avatars/
#   icons from arbitrary hosts. Tightening these to a build-generated allowlist
#   from a shared host constant is the next step; broad-https is the safe start.
